<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Armor" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/lcd_bg</item>
        <item name="android:colorBackground">@color/lcd_bg</item>
        <item name="android:textColor">@color/lcd_fg</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.Armor.NoBars" parent="Theme.Armor">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Splash background mimics the disguise home so cold-start is seamless. -->
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <!-- System does NOT draw bar backgrounds — our content extends everywhere. -->
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
