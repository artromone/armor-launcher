<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!--
        Same unified status bar every other screen uses. Title is intentionally
        left blank on home — the big clock block below takes over that role.
    -->
    <include layout="@layout/component_status_bar" />

    <!-- ================== BIG CLOCK (home signature) ================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D0D8E8"
            android:textSize="14sp"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- ================== PINNED APPS ================== -->
    <LinearLayout
        android:id="@+id/pinned_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/pinned_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:text="Press Menu, long-press Center to pin apps here."
        android:textColor="#888888"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- ================== STATUS LINE ================== -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="6dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_selected_dashed">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_tasks"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tasks created."
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- ================== WALLPAPER FILL ================== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_wallpaper" />

    <!-- ================== SOFT KEYS ================== -->
    <include layout="@layout/component_soft_keys" />
</LinearLayout>
